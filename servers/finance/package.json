{
  "name": "finance-server",
  "scripts": {
    "dev": "go run ./cmd/",
    "build": "go build -o finance-server ./cmd/",
    "start": "./finance-server",
    "test": "go test ./... -v",
    "test:coverage": "go test ./... -coverprofile=coverage.out -covermode=atomic && go tool cover -func=coverage.out",
    "lint": "go vet ./... && gofmt -l .",
    "format": "gofmt -w ."
  }
}
