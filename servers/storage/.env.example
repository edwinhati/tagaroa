ENV=development
PORT=8084

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/storage

# S3 Configuration
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=storage
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1

# CORS
TRUSTED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3004

# Authentication (OIDC) - Optional
OIDC_BASE_URL=http://localhost:8080/api/auth
OIDC_CLIENT_ID=http://localhost:8080
OIDC_CLIENT_SECRET=storage-client-secret
