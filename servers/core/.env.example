PORT=8080
BASE_URL=http://localhost
AUTH_APP_URL=http://localhost:3001
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/auth

# Google OAuth (Optional - for social login)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Environment
NODE_ENV=development

# Security (Production)
# JWT_SECRET=your-super-secure-jwt-secret-change-in-production
# ENCRYPTION_KEY=your-32-character-encryption-key
BETTER_AUTH_SECRET=generate-with-openssl-rand-base64-32

# Better Auth Infrastructure (Optional - for dashboard, analytics, security)
# Get your API key from https://better-auth.com/dashboard
# BETTER_AUTH_API_KEY=your-api-key

# CORS (comma-separated origins, defaults to localhost in development)
# TRUSTED_ORIGINS=https://app.example.com,https://admin.example.com

# S3 Storage Configuration
S3_PROVIDER=minio # minio | aws | r2
S3_BUCKET=uploads
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_ENDPOINT=http://localhost:9000 # For MinIO/R2

# Cloudflare R2 (if using R2 in production)
# CLOUDFLARE_ACCOUNT_ID=your-account-id

# File Upload Limits
MAX_FILE_SIZE=10485760 # 10MB in bytes

# Sentry Configuration (Error Tracking & Performance Monitoring)
# Get your DSN from https://sentry.io/settings/projects/
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_ENABLED=false
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=1.0

# Bun Native Profiling (Alternative to Sentry Profiling)
# These settings control Bun's built-in memory/CPU profiling
PROFILING_ENABLED=false
PROFILING_INTERVAL_MS=5000
PROFILING_MAX_SAMPLES=1000

# OpenTelemetry Configuration (Vendor-neutral observability)
# Supports Jaeger, Zipkin, Prometheus, and many other backends
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
OTEL_SERVICE_NAME=tagaroa-core