{
	"$schema": "https://turborepo.com/schema.json",
	"ui": "tui",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": [".next/**", "!.next/cache/**"],
			"env": ["NODE_ENV"]
		},
		"finance-server#build": {
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": ["finance-server"],
			"env": ["NODE_ENV"]
		},
		"lint": {
			"dependsOn": ["^lint"]
		},
		"check-types": {
			"dependsOn": ["^check-types"]
		},
		"test": {
			"dependsOn": ["^test"],
			"cache": false
		},
		"test:coverage": {
			"dependsOn": ["^test:coverage"],
			"cache": false
		},
		"dev": {
			"cache": false,
			"persistent": true
		}
	}
}
