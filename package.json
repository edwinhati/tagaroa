{
	"name": "tagaroa",
	"devDependencies": {
		"@biomejs/biome": "^2.3.8",
		"turbo": "^2.6.3",
		"typescript": "5.9.3"
	},
	"engines": {
		"node": ">=18"
	},
	"packageManager": "bun@1.3.3",
	"private": true,
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev",
		"lint": "turbo run lint",
		"format": "biome format --write",
		"check-types": "turbo run check-types"
	},
	"workspaces": [
		"apps/*",
		"servers/*",
		"packages/*"
	]
}
