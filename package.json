{
  "name": "tagaroa",
  "devDependencies": {
    "@biomejs/biome": "^2.4.2",
    "lefthook": "^2.1.1",
    "turbo": "^2.8.9",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.5",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "biome format --write",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "prepare": "lefthook install"
  },
  "workspaces": [
    "apps/*",
    "servers/*",
    "packages/*"
  ]
}
