{
	"name": "tagaroa",
	"devDependencies": {
		"@biomejs/biome": "^2.3.11",
		"lefthook": "^2.0.13",
		"turbo": "^2.7.3",
		"typescript": "5.9.3"
	},
	"engines": {
		"node": ">=18"
	},
	"packageManager": "bun@1.3.5",
	"private": true,
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev",
		"lint": "turbo run lint",
		"format": "biome format --write",
		"check-types": "turbo run check-types",
		"test": "turbo run test",
		"test:coverage": "turbo run test:coverage",
		"prepare": "lefthook install"
	},
	"workspaces": [
		"apps/*",
		"servers/*",
		"packages/*"
	]
}
